# ---------------------------------------------------------------------------
# WORLD CUP AI HUB — 环境变量示例
# 复制为 .env.local 后填入真实值（.env.local 已被 .gitignore 忽略，不会提交）。
# ---------------------------------------------------------------------------

# football-data.org：免费 10 次/分钟，适合免费双源模式下刷新实时比分/状态。
# 脚本：node scripts/ingest-scores.mjs
FOOTBALL_DATA_API_KEY=

# API-Football（dashboard.api-football.com）：
# 用途：实时比分、状态、阵容、事件、裁判、统计等服务端写库任务。
# 脚本：POLLER_ENABLED=1 node scripts/poller.mjs
API_FOOTBALL_KEY=

# poller 显式开关。为避免误启动常驻写库任务，运行 poller 时必须设为 1。
POLLER_ENABLED=0

# 智谱 GLM（open.bigmodel.cn）：生成「关键因素对比」AI 分析，结果入库缓存，前台零实时调用。
# glm-4-flash 免费；OpenAI 兼容接口，可改 GLM_BASE_URL / GLM_MODEL 切换其它 provider（如 DeepSeek）。
# 脚本：node scripts/ingest-factors.mjs [match_key ...]
GLM_API_KEY=
# GLM_MODEL=glm-4-flash
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# 小米 MiMo：可选，用于联网搜索预测阵容、赛前伤停/发布会/天气/赔率走势。
# 真实值也可以放在 config/secrets/keys.local.mjs；不要使用 NEXT_PUBLIC_*。
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
MIMO_WEB_SEARCH=true
# MIMO_SEARCH_DELAY_MS=800
